{
  "// Description": "Claude Code Settings - Comprehensive Template",
  "// Documentation": "https://code.claude.com/docs/en/settings",
  
  "// ============ PERMISSIONS ============": "",
  "permissions": {
    "// Safe commands that don't require approval": "",
    "allow": [
      "Bash(echo:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(npm run test:*)",
      "Bash(npm run lint:*)"
    ],
    
    "// Commands that need approval": "",
    "ask": [
      "Edit",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npm install:*)",
      "Bash(docker:*)"
    ],
    
    "// Blocked commands for security": "",
    "deny": [
      "WebFetch",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Read(./secrets/**)",
      "Read(.env)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Edit(./secrets/**)",
      "Edit(.env)"
    ]
  },
  
  "// ============ MCP SERVERS ============": "",
  "lazyLoadMcp": true,
  "mcpToolLoadThreshold": 0.1,
  
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/Documents",
        "~/Projects"
      ]
    }
  },
  
  "disabledMcpjsonServers": [],
  
  "// ============ HOOKS ============": "",
  "hooks": {
    "post-edit": {
      "matcher": "Edit",
      "command": "prettier --write $FILE"
    }
  },
  
  "// ============ PERFORMANCE ============": "",
  "autoCompactThreshold": 0.70,
  "disableAutoCompact": false,
  
  "// ============ TIMEOUTS ============": "",
  "MCP_TOOL_TIMEOUT": 60000,
  "BASH_MAX_TIMEOUT_MS": 120000,
  
  "// ============ SECURITY ============": "",
  "maxTranscriptRetentionDays": 14,
  "enableAuditLog": true,
  
  "// ============ NOTES ============": "",
  "// 1. Environment variables: Use ${VAR_NAME} syntax": "",
  "// 2. Settings precedence: Enterprise > CLI > Local > Shared > User": "",
  "// 3. Restart Claude Code after changes": "",
  "// 4. Test with: /permissions and /mcp commands": ""
}
